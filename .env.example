# Sift environment variables (see CONTRACTS.md)

# Postgres connection
DATABASE_URL=postgres://localhost:5432/agentic_crm

# LLM — any OpenAI-compatible endpoint; unset key => MockHermesClient (offline demo mode)
#   Nous Hermes: HERMES_BASE_URL=https://inference.nousresearch.com/v1  HERMES_MODEL=Hermes-4-405B
#   OpenAI:      HERMES_BASE_URL=https://api.openai.com/v1              HERMES_MODEL=gpt-5
HERMES_API_KEY=
HERMES_BASE_URL=https://inference.nousresearch.com/v1
HERMES_MODEL=Hermes-4-405B

# Composio (Gmail) — unset key => gmail source reads backend/pipelines/fixtures/gmail.json
COMPOSIO_API_KEY=

# WhatsApp sidecar — unreachable => whatsapp source reads backend/pipelines/fixtures/whatsapp.json
SIDECAR_URL=http://localhost:3001

# Shared secret between Django and sidecar
INGEST_SECRET=dev-ingest-secret

# Langfuse observability — unset keys => tracing no-ops (offline demo still runs).
# Create a free project at https://cloud.langfuse.com (or self-host) and paste keys.
#   Cloud EU: https://cloud.langfuse.com   Cloud US: https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
